          "max": 240,
          "min": 16,
          "step": 8,
          "type": "number",
          "unit": "px"
        },
        {
          "default": true,
          "description": "开启后让整理结果尽量落在画布中央区域。",
          "group": "位置与尺寸",
          "id": "centerLayout",
          "label": "整理后围绕画布中心",
          "type": "boolean"
