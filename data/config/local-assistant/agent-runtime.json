          "max": 2,
          "min": 0,
          "step": 1,
          "type": "number",
          "unit": "次"
        },
        {
          "default": true,
          "description": "开启后 Kimi、Gemini 不可用时可尝试通义视觉模型；关闭后只使用支持超长上下文的模型。",
          "group": "运行与容错",
          "id": "allowStandardVisionFallback",
          "label": "允许普通视觉模型兜底",
          "type": "boolean"
