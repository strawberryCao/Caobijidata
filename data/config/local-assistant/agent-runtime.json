            },
            {
              "label": "均衡",
              "value": "balanced"
            },
            {
              "label": "深度",
              "value": "deep"
            }
          ],
          "type": "select"
        },
        {
          "default": "fixed",
          "description": "固定模式更适合 Kimi 等推理模型；自适应会按节点数量压缩预算，可能让长推理占满预算。",
